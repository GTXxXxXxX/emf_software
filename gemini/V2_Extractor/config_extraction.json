  "json_schema" : {
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExtractionFactureMusique",
  "type": "object",
  "properties": {
    "dealer": { "type": "string" },
    "invoice_date": { "type": "string", "pattern": "^[0-9]{2}/[0-9]{2}/[0-9]{4}$" },
    "invoice_number": { "type": "string" },
    "freight": { "type": "number" },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "quantity": { "type": "integer" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "unit_price": { "type": "number" },
          "extended_price": { "type": "number" },
          "competition": { "type": "string", "format": "uri" },
          "competition_price": { "type": "number" },
          "competition_price_confidence": { "type": "string" }
        },
        "required": ["product_id", "quantity", "category", "unit_price"]
      }
    },
    "tps": { "type": "number" },
    "tvq": { "type": "number" },
    "sub_total": { "type": "number" },
    "total": { "type": "number" }
  },
  "required": ["dealer", "invoice_number", "products", "total"]
}
